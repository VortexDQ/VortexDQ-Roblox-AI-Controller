# AI Model API Keys (At least one required, or use Ollama)

# Claude API (Recommended - best quality)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini (Fast, good quality)
GEMINI_API_KEY=

# OpenAI (Codex/GPT-4)
OPENAI_API_KEY=

# DeepSeek (Cost-effective)
DEEPSEEK_API_KEY=

# Cursor AI
CURSOR_API_KEY=

# Server Configuration
PORT=7777
NODE_ENV=development

# Optional: Ollama settings (for local/offline)
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=mistral
